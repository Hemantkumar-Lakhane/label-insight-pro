# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Force bash scripts and configuration to retain LF
*.sh text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.py text eol=lf

# Force Windows batch files to retain CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
