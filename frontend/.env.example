# ==============================================================================
# FRONTEND CONFIGURATION (Vite React App)
# Place these in the root .env file
# ==============================================================================

# Supabase Web App API credentials
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anonymous-key-here

# Local or Production FastAPI backend server URL
VITE_BACKEND_URL=http://localhost:8000

# ==============================================================================
# BACKEND CONFIGURATION (FastAPI Python Service)
# Place these in the backend/.env file (or root .env if shared)
# ==============================================================================

# Supabase credentials (used by the Python backend to resolve user profile details)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-key-here

# ==============================================================================
# EDGE FUNCTIONS CONFIGURATION (Supabase Deno Edge Functions)
# Deploy these using `supabase secrets set`
# ==============================================================================

# Google Gemini API key used by the Deno Edge Functions to analyze ingredients
GEMINI_API_KEY=your-gemini-api-key-here

# OCR.space API key (used as visual scanner fallback if PaddleOCR is unavailable)
# Register a free key at: https://ocr.space/OCRAPI
OCR_SPACE_API_KEY=your-ocr-space-api-key-here

# PaddleOCR microservice connection endpoint
PADDLE_OCR_URL=http://host.docker.internal:8000/ocr
